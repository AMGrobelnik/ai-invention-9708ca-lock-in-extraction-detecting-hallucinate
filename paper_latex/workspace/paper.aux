\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Hallucination-detection AUROC on three real benchmarks under the T1 canonicalization failure (21\% cross-variant atom agreement). Lock-in and LOO collapse to near-random performance (0.528--0.700) because the presence vectors are unreliable. LLM self-judge and embedding similarity remain strong baselines. Error bars show 95\% bootstrap confidence intervals.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:real_auroc}{{2}{7}{Hallucination-detection AUROC on three real benchmarks under the T1 canonicalization failure (21\% cross-variant atom agreement). Lock-in and LOO collapse to near-random performance (0.528--0.700) because the presence vectors are unreliable. LLM self-judge and embedding similarity remain strong baselines. Error bars show 95\% bootstrap confidence intervals}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Real-Data AUROC}{7}{subsection.4.5}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Hallucination-detection AUROC on real benchmarks (95\% bootstrap CIs). Lock-in and LOO are degraded by the T1 canonicalization failure (21\% agreement). Self-consistency achieves AUROC $= 0.50$ because all atoms are equally consistent under re-extraction (a degenerate result at $K=5$ runs).}}{7}{table.1}\protected@file@percent }
\newlabel{tab:real}{{1}{7}{Hallucination-detection AUROC on real benchmarks (95\% bootstrap CIs). Lock-in and LOO are degraded by the T1 canonicalization failure (21\% agreement). Self-consistency achieves AUROC $= 0.50$ because all atoms are equally consistent under re-extraction (a degenerate result at $K=5$ runs)}{table.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.6}Simulation Under Ideal Canonicalization \let \reserved@d =[\def \par }{8}{subsection.4.6}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Bootstrap AUROC (2000 stratified resamples, $n=200$ atoms) under ideal canonicalization. Lock-in CIs overlap LLM self-judge but are non-overlapping with all other baselines.}}{8}{table.2}\protected@file@percent }
\newlabel{tab:sim}{{2}{8}{Bootstrap AUROC (2000 stratified resamples, $n=200$ atoms) under ideal canonicalization. Lock-in CIs overlap LLM self-judge but are non-overlapping with all other baselines}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Bootstrap AUROC (2000 stratified resamples, $n=200$ atoms, FactScore-synthetic dataset) under the assumption that the T1 canonicalization gate is met ($\geq 85\%$ agreement). Lock-in achieves AUROC 0.979 [0.951, 0.997], with CIs non-overlapping with all baselines except LLM self-judge (overlap: 0.001). Error bars show 95\% bootstrap CIs.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:sim_auroc}{{3}{8}{Bootstrap AUROC (2000 stratified resamples, $n=200$ atoms, FactScore-synthetic dataset) under the assumption that the T1 canonicalization gate is met ($\geq 85\%$ agreement). Lock-in achieves AUROC 0.979 [0.951, 0.997], with CIs non-overlapping with all baselines except LLM self-judge (overlap: 0.001). Error bars show 95\% bootstrap CIs}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Left: AUROC as a function of $K$ (number of Hadamard variants) for lock-in and LOO at equal extraction budget. The log-linear fit gives slope $0.403 \pm 0.021$ for lock-in (predicted: $0.50$; $R^2=0.999$) and $0.367 \pm 0.048$ for LOO. Right: lock-in AUROC K-curve rising from 0.727 ($K=1$) to 1.000 ($K=32$), log-linear $R^2=0.84$.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:kcurve}{{4}{9}{Left: AUROC as a function of $K$ (number of Hadamard variants) for lock-in and LOO at equal extraction budget. The log-linear fit gives slope $0.403 \pm 0.021$ for lock-in (predicted: $0.50$; $R^2=0.999$) and $0.367 \pm 0.048$ for LOO. Right: lock-in AUROC K-curve rising from 0.727 ($K=1$) to 1.000 ($K=32$), log-linear $R^2=0.84$}{figure.4}{}}
